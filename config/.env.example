# Pythia Environment Configuration
# Copy this file to .env and fill in your actual credentials
# NEVER commit the .env file to version control!

# ============================================
# Coinbase Advanced Trade API
# ============================================
# Get credentials from: https://www.coinbase.com/settings/api
COINBASE_API_KEY=your_api_key_here
COINBASE_API_SECRET=your_api_secret_here

# For ES256 JWT authentication (PEM format)
# The private key file path for ECDSA P-256 signing
COINBASE_PRIVATE_KEY_PATH=/path/to/coinbase_private_key.pem

# Alternative: Inline private key (base64 encoded)
# COINBASE_PRIVATE_KEY_B64=your_base64_encoded_private_key

# ============================================
# Exchange Configuration (CCXT)
# ============================================
# Enable rate limiting
CCXT_RATE_LIMIT=True

# Sandbox mode (for testing)
CCXT_SANDBOX=False

# ============================================
# Database Configuration
# ============================================
# DuckDB database path
DATABASE_PATH=data/pythia.duckdb

# Enable WAL mode for concurrent reads
DATABASE_WAL_MODE=True

# ============================================
# Logging Configuration
# ============================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=logs/pythia.log

# ============================================
# Monitoring & Alerts
# ============================================
# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Email Alerts (optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_email_password
ALERT_EMAIL_RECIPIENTS=trader1@example.com,trader2@example.com

# ============================================
# Trading Configuration
# ============================================
# Environment: development, staging, production
ENVIRONMENT=development

# Paper trading mode (True = no real orders)
PAPER_TRADING=True

# Initial capital (USD)
INITIAL_CAPITAL=10000

# ============================================
# Model Configuration
# ============================================
# Device for PyTorch: mps, cuda, cpu
TORCH_DEVICE=mps

# Enable MPS fallback to CPU if unavailable
MPS_FALLBACK=True

# Model checkpoint directory
MODEL_CHECKPOINT_DIR=models/checkpoints

# ============================================
# Security
# ============================================
# API IP whitelist (comma-separated)
API_IP_WHITELIST=

# Max concurrent connections
MAX_CONCURRENT_CONNECTIONS=10

# Request timeout (seconds)
REQUEST_TIMEOUT=30

# ============================================
# Performance
# ============================================
# Number of asyncio workers
MAX_WORKERS=4

# Batch size for database writes
DB_BATCH_SIZE=1000

# WebSocket message queue size
WS_QUEUE_SIZE=10000

# ============================================
# Development & Debugging
# ============================================
# Enable debug mode
DEBUG=False

# Enable profiling
ENABLE_PROFILING=False

# Save raw WebSocket messages (for debugging)
SAVE_RAW_MESSAGES=False

# ============================================
# Backtesting
# ============================================
# Backtest start date (YYYY-MM-DD)
BACKTEST_START_DATE=2021-01-01

# Backtest end date (YYYY-MM-DD)
BACKTEST_END_DATE=2024-01-01

# ============================================
# Feature Flags
# ============================================
# Enable experimental features
ENABLE_EXPERIMENTAL_FEATURES=False

# Enable ensemble model
ENABLE_ENSEMBLE=True

# Enable walk-forward validation
ENABLE_WALK_FORWARD=True

# Enable SMOTE oversampling
ENABLE_SMOTE=True
