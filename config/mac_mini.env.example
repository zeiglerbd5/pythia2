# Pythia Mac Mini Environment Configuration
# Copy this to config/mac_mini.env and fill in your values
# DO NOT commit mac_mini.env to git!

# Coinbase API credentials (required for trading, optional for data collection)
COINBASE_API_KEY=your_api_key_here
COINBASE_API_SECRET=your_api_secret_here

# Environment
PYTHIA_ENV=production

# Paths (relative to project root, adjust if needed)
PYTHIA_DB_PATH=market_data.duckdb
PYTHIA_LOG_DIR=logs

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: Feature calculation settings
# FEATURE_LOOKBACK_BARS=100
# PRIMARY_TIMEFRAME=1m
